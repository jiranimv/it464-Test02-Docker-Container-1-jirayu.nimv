# ระบุชื่อตัวแปรที่ใช้ใน compose.yaml เพื่อให้สอดคล้องกับการใช้งานในไฟล์นั้น
PROJECT_NAME=it464-Test02-Docker-Container-1-jirayu.nimv

MY_USERNAME= jiranimv #ใส่ชื่อผู้ใช้ของคุณ
# พอร์ตที่ใช้สำหรับบริการต่าง ๆ

# พอร์ตสำหรับ Web Proxy (Nginx)
HTTP_PORT=10401
# พอร์ตสำหรับ phpMyAdmin
PMA_PORT=10402
# DB Details
DB_USER=root
DB_NAME=jiranimv-storage